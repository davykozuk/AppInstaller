<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppInstaller V5" Height="650" Width="1000"
        Background="#ECF0F1">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.ColumnSpan="2"
                Background="#FFFFFF"
                CornerRadius="5"
                Padding="5"
                Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal">

                <Button x:Name="BtnScan"
                        Content="Scanner les logiciels"
                        Background="#3498DB"
                        Foreground="White"
                        Padding="10,5"
                        Margin="5"/>

                <Button x:Name="BtnInstall"
                        Content="Installer selection"
                        Background="#27AE60"
                        Foreground="White"
                        Padding="10,5"
                        Margin="5"/>

                <CheckBox x:Name="ChkSilent"
                          Content="Mode silencieux"
                          VerticalAlignment="Center"
                          Margin="15,0"/>
            </StackPanel>
        </Border>

        <!-- LISTE LOGICIELS -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="White"
                CornerRadius="5"
                Padding="5">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SoftwareList"/>
            </ScrollViewer>

        </Border>

        <!-- LOGS -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#1E1E1E"
                CornerRadius="5"
                Margin="10,0,0,0"
                Padding="5">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Logs"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="5"/>

                <!-- 🔥 Scroll FIX -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <TextBox x:Name="LogBox"
                             Background="#1E1E1E"
                             Foreground="#00FF9C"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"/>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- LOADER -->
        <Border x:Name="LoaderOverlay"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Background="#80000000"
                Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="Chargement..."
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <ProgressBar Width="200"
                             Height="20"
                             IsIndeterminate="True"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>