<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppInstaller V6" Height="650" Width="950">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2C3E50" Padding="10" CornerRadius="5">
            <DockPanel>

                <TextBlock Text="AppInstaller V6"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">

                    <Button x:Name="BtnScan"
                            Content="Scan"
                            Margin="5"
                            Padding="10,5"
                            Background="#3498DB"
                            Foreground="White"
                            ToolTip="Scan installed software"/>

                    <Button x:Name="BtnInstall"
                            Content="Install selected"
                            Margin="5"
                            Padding="10,5"
                            Background="#27AE60"
                            Foreground="White"
                            ToolTip="Install selected software"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- LIST -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="5">
            <StackPanel x:Name="AppListPanel"/>
        </ScrollViewer>

        <!-- LOGS -->
        <Border Grid.Row="1" Grid.Column="1" Margin="5" Background="#1E1E1E" CornerRadius="5">
            <TextBox x:Name="LogBox"
                     Background="#1E1E1E"
                     Foreground="#00FFAA"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Border>

    </Grid>
</Window>