<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppInstaller V5" Height="650" Width="900">

<Grid Margin="10">

    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- TOP BAR -->
    <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2" Margin="5">

        <TextBlock Text="Categorie :" VerticalAlignment="Center"/>

        <ComboBox x:Name="CategoryFilter" Width="200" Margin="10,0"/>

        <Button x:Name="BtnInstall"
                Content="Installer selection"
                Background="#27AE60"
                Foreground="White"
                Margin="10,0"/>

        <CheckBox x:Name="ChkSilent"
                  Content="Mode silencieux"
                  Margin="10,0"/>
    </StackPanel>

    <!-- LISTE -->
    <ScrollViewer Grid.Row="1" Grid.Column="0">
        <StackPanel x:Name="SoftwareList"/>
    </ScrollViewer>

    <!-- LOGS -->
    <Border Grid.Row="1" Grid.Column="1"
            Background="#1E1E1E"
            CornerRadius="5"
            Margin="10,0,0,0">

        <StackPanel>
            <TextBlock Text="Logs"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="5"/>

            <TextBox x:Name="LogBox"
                     Background="#1E1E1E"
                     Foreground="#00FF9C"
                     BorderThickness="0"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
    </Border>

</Grid>
</Window>