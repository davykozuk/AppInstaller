<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppInstaller V4" Height="600" Width="800">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock Text="Logiciels disponibles" FontSize="18" Margin="5"/>

            <ScrollViewer Height="300">
                <StackPanel x:Name="SoftwareList"/>
            </ScrollViewer>

            <TextBlock Text="Logs" Margin="5"/>
            <TextBox x:Name="LogBox" Height="150" Background="Black" Foreground="White"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <CheckBox x:Name="ChkSilent" Content="Silencieux" Margin="5"/>
            <Button x:Name="BtnInstall" Content="Installer" Margin="5" Background="Green"/>
        </StackPanel>

    </Grid>
</Window>