<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppInstaller V5" Height="700" Width="1050"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#DDE1E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#128230;" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="AppInstaller" FontSize="18" FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock x:Name="TxtStatus" Text="Pret" FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkSilent" Content="Mode silencieux"
                              Margin="0,0,14,0" VerticalAlignment="Center" Foreground="#555"/>
                    <Button x:Name="BtnScan" Content="Scanner"
                            Background="#3498DB" Style="{StaticResource PrimaryBtn}"/>
                    <Button x:Name="BtnInstall" Content="Installer"
                            Background="#27AE60" Style="{StaticResource PrimaryBtn}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BARRE RECHERCHE -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" Style="{StaticResource SearchBox}" VerticalAlignment="Center"/>

                <Button x:Name="BtnSelectAll" Grid.Column="1"
                        Content="Tout selectionner" Background="#8E44AD"
                        Style="{StaticResource PrimaryBtn}" Margin="8,0,4,0"/>
                <Button x:Name="BtnDeselectAll" Grid.Column="2"
                        Content="Tout deselectionner" Background="#7F8C8D"
                        Style="{StaticResource PrimaryBtn}" Margin="0"/>
            </Grid>
        </Border>

        <!-- CONTENU PRINCIPAL -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- LISTE APPS -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalFirst">
                    <StackPanel x:Name="SoftwareList" Margin="4"/>
                </ScrollViewer>
            </Border>

            <!-- LOGS -->
            <Border Grid.Column="2" Background="#1A1D23" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#23272E" CornerRadius="10,10,0,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#E74C3C" Margin="0,0,5,0"/>
                            <Ellipse Width="10" Height="10" Fill="#F39C12" Margin="0,0,5,0"/>
                            <Ellipse Width="10" Height="10" Fill="#27AE60" Margin="0,0,10,0"/>
                            <TextBlock Text="Console" Foreground="#AAB2BF"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="LogBox"
                                 Background="Transparent"
                                 Foreground="#98C379"
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="11"
                                 Padding="12,8"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#23272E" CornerRadius="0,0,10,10" Padding="8,4">
                        <Button x:Name="BtnClearLog" Content="Effacer"
                                Background="#3D4451" Foreground="#AAB2BF"
                                Style="{StaticResource PrimaryBtn}"
                                FontSize="11" Padding="10,4" HorizontalAlignment="Right"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- BARRE DE STATUT -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="12,6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtInstalled" Text="-- installes" Foreground="#27AE60"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,14,0"/>
                    <TextBlock x:Name="TxtAvailable" Text="-- disponibles" Foreground="#3498DB"
                               FontSize="12" Margin="0,0,14,0"/>
                    <TextBlock x:Name="TxtUpdates" Text="" Foreground="#F39C12"
                               FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

                <ProgressBar x:Name="ProgressBar" Grid.Column="1"
                             Width="180" Height="8" Minimum="0" Maximum="100" Value="0"
                             Foreground="#3498DB" Background="#DDE1E7"
                             Visibility="Collapsed" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- OVERLAY CHARGEMENT -->
        <Border x:Name="LoaderOverlay"
                Grid.RowSpan="4"
                Background="#CC000000"
                Visibility="Collapsed"
                CornerRadius="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="LoaderText" Text="Chargement..."
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <ProgressBar Width="240" Height="6" IsIndeterminate="True"
                             Foreground="#3498DB" Background="#444"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
